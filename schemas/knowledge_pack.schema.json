{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/safety-engine/knowledge_pack.schema.json",
  "title": "Safety Engine Knowledge Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_meta",
    "sources",
    "ingredients",
    "evidence_chunks",
    "safety_rules",
    "sample_user_profile",
    "sample_evaluation_input",
    "sample_engine_output"
  ],
  "properties": {
    "package_meta": {
      "type": "object"
    },
    "sources": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://example.local/safety-engine/source.schema.json",
        "title": "Source Registry Entry",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "title",
          "source_type",
          "organization",
          "jurisdiction",
          "publication_year",
          "publication_date",
          "url",
          "doi",
          "pmid",
          "authors",
          "journal",
          "evidence_tier",
          "access_model",
          "ingestion_status",
          "notes_ko"
        ],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "source_type": {
            "type": "string"
          },
          "organization": {
            "type": [
              "string",
              "null"
            ]
          },
          "jurisdiction": {
            "type": [
              "string",
              "null"
            ]
          },
          "publication_year": {
            "type": [
              "integer",
              "null"
            ]
          },
          "publication_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "url": {
            "type": [
              "string",
              "null"
            ]
          },
          "doi": {
            "type": [
              "string",
              "null"
            ]
          },
          "pmid": {
            "type": [
              "string",
              "null"
            ]
          },
          "authors": {
            "type": [
              "array",
              "string",
              "null"
            ],
            "items": {
              "type": "string"
            }
          },
          "journal": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_tier": {
            "type": [
              "string",
              "null"
            ]
          },
          "access_model": {
            "type": [
              "string",
              "null"
            ]
          },
          "ingestion_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes_ko": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "ingredients": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://example.local/safety-engine/ingredient.schema.json",
        "title": "Ingredient Entry",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ingredient_id",
          "ingredient_name_ko",
          "ingredient_name_en",
          "category",
          "forms",
          "matching_aliases_ko",
          "matching_aliases_en",
          "quality_notes_ko"
        ],
        "properties": {
          "ingredient_id": {
            "type": "string"
          },
          "ingredient_name_ko": {
            "type": "string"
          },
          "ingredient_name_en": {
            "type": [
              "string",
              "null"
            ]
          },
          "category": {
            "type": [
              "string",
              "null"
            ]
          },
          "forms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "matching_aliases_ko": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "matching_aliases_en": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "quality_notes_ko": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "evidence_chunks": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://example.local/safety-engine/evidence_chunk.schema.json",
        "title": "Evidence Chunk Entry",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chunk_id",
          "source_id",
          "ingredient_ids",
          "locator_type",
          "locator_value",
          "excerpt_summary_ko",
          "claim_type",
          "structured_claim",
          "confidence",
          "notes_ko"
        ],
        "properties": {
          "chunk_id": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "ingredient_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "locator_type": {
            "type": "string"
          },
          "locator_value": {
            "type": "string"
          },
          "excerpt_summary_ko": {
            "type": "string"
          },
          "claim_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "structured_claim": {
            "type": [
              "object",
              "array",
              "string",
              "number",
              "boolean",
              "null"
            ]
          },
          "confidence": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes_ko": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "safety_rules": {
      "type": "array",
      "items": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$id": "https://example.local/safety-engine/safety_rule.schema.json",
        "title": "Safety Rule Entry",
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "rule_group_id",
          "ingredient_id",
          "rule_name_ko",
          "rule_category",
          "severity",
          "priority",
          "jurisdiction",
          "applies_when",
          "threshold_operator",
          "threshold_value",
          "threshold_unit",
          "threshold_scope",
          "action_text_ko",
          "rationale_ko",
          "monitoring_ko",
          "exception_ko",
          "evidence_chunk_ids",
          "source_ids",
          "review_status",
          "schema_note"
        ],
        "properties": {
          "rule_id": {
            "type": "string"
          },
          "rule_group_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "ingredient_id": {
            "type": "string"
          },
          "rule_name_ko": {
            "type": "string"
          },
          "rule_category": {
            "type": "string"
          },
          "severity": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "jurisdiction": {
            "type": [
              "string",
              "null"
            ]
          },
          "applies_when": {
            "type": "object"
          },
          "threshold_operator": {
            "type": [
              "string",
              "null"
            ]
          },
          "threshold_value": {
            "type": [
              "number",
              "integer",
              "null"
            ]
          },
          "threshold_unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "threshold_scope": {
            "type": [
              "string",
              "null"
            ]
          },
          "action_text_ko": {
            "type": "string"
          },
          "rationale_ko": {
            "type": "string"
          },
          "monitoring_ko": {
            "type": [
              "string",
              "null"
            ]
          },
          "exception_ko": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_chunk_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "review_status": {
            "type": "string"
          },
          "schema_note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "sample_user_profile": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://example.local/safety-engine/user_profile.schema.json",
      "title": "User Profile",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "user_id",
        "age_years",
        "sex",
        "pregnancy_status",
        "lactation_status",
        "smoking_status",
        "exposures",
        "medications",
        "conditions",
        "allergies",
        "devices",
        "immune_status",
        "goals"
      ],
      "properties": {
        "user_id": {
          "type": "string"
        },
        "age_years": {
          "type": [
            "integer",
            "null"
          ]
        },
        "sex": {
          "type": [
            "string",
            "null"
          ]
        },
        "pregnancy_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "lactation_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "smoking_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "exposures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "medications": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "name",
              "dose",
              "frequency"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "dose": {
                "type": [
                  "string",
                  "number",
                  "integer",
                  "null"
                ]
              },
              "frequency": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allergies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "devices": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "immune_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sample_evaluation_input": {
      "type": "object"
    },
    "sample_engine_output": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "https://example.local/safety-engine/engine_output.schema.json",
      "title": "Safety Engine Output",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "evaluation_id",
        "evaluated_at",
        "engine_version",
        "jurisdiction_preference",
        "strictest_mode_for_conflicts",
        "overall_decision",
        "summary_ko",
        "blocked_ingredients",
        "dose_adjust_required_ingredients",
        "manual_review_required_ingredients",
        "top_risks",
        "ingredient_results",
        "reference_bundle"
      ],
      "properties": {
        "evaluation_id": {
          "type": "string"
        },
        "evaluated_at": {
          "type": "string"
        },
        "engine_version": {
          "type": "string"
        },
        "jurisdiction_preference": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strictest_mode_for_conflicts": {
          "type": "boolean"
        },
        "overall_decision": {
          "type": "string"
        },
        "summary_ko": {
          "type": "string"
        },
        "blocked_ingredients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dose_adjust_required_ingredients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manual_review_required_ingredients": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "top_risks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "ingredient_id",
              "ingredient_name_ko",
              "decision",
              "headline_ko"
            ],
            "properties": {
              "ingredient_id": {
                "type": "string"
              },
              "ingredient_name_ko": {
                "type": "string"
              },
              "decision": {
                "type": "string"
              },
              "headline_ko": {
                "type": "string"
              }
            }
          }
        },
        "ingredient_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "ingredient_id",
              "ingredient_name_ko",
              "candidate_label",
              "decision",
              "matched_rule_ids",
              "warnings_ko",
              "monitoring_ko",
              "references"
            ],
            "properties": {
              "ingredient_id": {
                "type": "string"
              },
              "ingredient_name_ko": {
                "type": "string"
              },
              "candidate_label": {
                "type": "string"
              },
              "decision": {
                "type": "string"
              },
              "matched_rule_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "warnings_ko": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "monitoring_ko": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "references": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": [
                    "source_id",
                    "title",
                    "locator",
                    "chunk_id",
                    "summary_ko",
                    "url"
                  ],
                  "properties": {
                    "source_id": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "locator": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "chunk_id": {
                      "type": "string"
                    },
                    "summary_ko": {
                      "type": "string"
                    },
                    "url": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "reference_bundle": {
          "type": "object"
        }
      }
    }
  }
}