{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.research/schemas/otc/product.schema.json",
  "title": "Korean OTC product",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_id", "item_sequence", "product_name", "manufacturer_name",
    "classification", "authorization_status", "dosage_form", "route",
    "active_ingredient_raw", "dose_per_administration", "administrations_per_day",
    "max_daily_dose", "minimum_dose_interval", "age_restriction", "indications",
    "dosage_and_administration", "warnings", "contraindications", "drug_interactions",
    "pregnancy_lactation", "hepatic_renal", "authorization_document_url",
    "source_id", "source_locator", "retrieved_at", "source_sha256", "record_status"
  ],
  "properties": {
    "product_id": {"type": "string", "minLength": 1},
    "item_sequence": {"type": "string", "pattern": "^[0-9]+$"},
    "product_name": {"type": "string", "minLength": 1},
    "manufacturer_name": {"type": "string", "minLength": 1},
    "classification": {"const": "일반의약품"},
    "authorization_status": {"enum": ["active", "withdrawn", "cancelled", "unknown"]},
    "dosage_form": {"type": "string"},
    "route": {"type": "string"},
    "active_ingredient_raw": {"type": "string"},
    "dose_per_administration": {"type": "string"},
    "administrations_per_day": {"type": "string"},
    "max_daily_dose": {"type": "string"},
    "minimum_dose_interval": {"type": "string"},
    "age_restriction": {"type": "string"},
    "indications": {"type": "string"},
    "dosage_and_administration": {"type": "string"},
    "warnings": {"type": "string"},
    "contraindications": {"type": "string"},
    "drug_interactions": {"type": "string"},
    "pregnancy_lactation": {"type": "string"},
    "hepatic_renal": {"type": "string"},
    "authorization_document_url": {"type": "string", "format": "uri"},
    "source_id": {"type": "string", "minLength": 1},
    "source_locator": {"type": "string", "minLength": 1},
    "retrieved_at": {"type": "string", "format": "date"},
    "source_sha256": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "record_status": {"enum": ["raw", "normalized", "verified_from_source", "rejected"]}
  }
}
