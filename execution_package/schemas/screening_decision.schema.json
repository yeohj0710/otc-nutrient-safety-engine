{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScreeningDecision",
  "type": "object",
  "required": [
    "record_id",
    "stage",
    "reviewer_id",
    "decision",
    "timestamp"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "study_family_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "stage": {
      "enum": [
        "title_abstract",
        "full_text"
      ]
    },
    "reviewer_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": [
        "include",
        "exclude",
        "uncertain"
      ]
    },
    "exclusion_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "ai_visible": {
      "type": "boolean"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
