{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExtractionRecord",
  "type": "object",
  "required": [
    "extraction_id",
    "study_family_id",
    "clinical_node_id",
    "study_design",
    "population",
    "exposure",
    "outcomes",
    "extractor_id",
    "verifier_id",
    "report_id",
    "verification_status"
  ],
  "properties": {
    "extraction_id": {
      "type": "string"
    },
    "study_family_id": {
      "type": "string"
    },
    "clinical_node_id": {
      "enum": [
        "A1",
        "A2",
        "R1",
        "R2",
        "R3"
      ]
    },
    "study_design": {
      "type": "string"
    },
    "population": {
      "type": "object"
    },
    "exposure": {
      "type": "object"
    },
    "comparator": {
      "type": [
        "object",
        "null"
      ]
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "outcome_id",
          "locator"
        ],
        "properties": {
          "outcome_id": {
            "type": "string"
          },
          "effect_measure": {
            "type": [
              "string",
              "null"
            ]
          },
          "effect_value": {
            "type": [
              "number",
              "null"
            ]
          },
          "ci_lower": {
            "type": [
              "number",
              "null"
            ]
          },
          "ci_upper": {
            "type": [
              "number",
              "null"
            ]
          },
          "events": {
            "type": [
              "integer",
              "null"
            ]
          },
          "total": {
            "type": [
              "integer",
              "null"
            ]
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "timepoint": {
            "type": [
              "string",
              "null"
            ]
          },
          "locator": {
            "type": "string"
          },
          "supporting_quote": {
            "type": "string"
          }
        }
      }
    },
    "extractor_id": {
      "type": "string",
      "minLength": 1
    },
    "verifier_id": {
      "type": "string",
      "minLength": 1
    },
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "verification_status": {
      "enum": [
        "unverified",
        "verified",
        "adjudicated"
      ]
    }
  },
  "additionalProperties": false
}
