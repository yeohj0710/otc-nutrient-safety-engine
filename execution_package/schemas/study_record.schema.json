{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StudyRecord",
  "type": "object",
  "required": [
    "record_id",
    "source_database",
    "title",
    "raw_source_path",
    "raw_source_sha256"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "study_family_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_database": {
      "type": "string",
      "minLength": 1
    },
    "database_record_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "pmid": {
      "type": [
        "string",
        "null"
      ]
    },
    "doi": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "abstract": {
      "type": [
        "string",
        "null"
      ]
    },
    "year": {
      "type": [
        "integer",
        "null"
      ]
    },
    "language": {
      "type": [
        "string",
        "null"
      ]
    },
    "raw_source_path": {
      "type": "string",
      "minLength": 1
    },
    "raw_source_sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    }
  },
  "additionalProperties": false
}
