{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EvidenceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "clinical_node_id",
    "evidence_layer",
    "report_ids",
    "outcome_id",
    "claim",
    "certainty_grade",
    "source_quote_ids",
    "reviewer_ids",
    "status"
  ],
  "properties": {
    "evidence_id": {"type": "string", "minLength": 1},
    "clinical_node_id": {"enum": ["A1", "A2", "R1", "R2", "R3"]},
    "evidence_layer": {
      "enum": ["clinical_effect", "adverse_event_signal", "normative_threshold", "guideline_recommendation"]
    },
    "study_family_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "report_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "outcome_id": {"type": "string", "minLength": 1},
    "population_scope": {"type": "object"},
    "exposure_scope": {"type": "object"},
    "claim": {"type": "string", "minLength": 1},
    "effect_summary": {"type": ["object", "null"]},
    "certainty_grade": {"enum": ["high", "moderate", "low", "very_low", "not_graded"]},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "source_quote_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "reviewer_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "status": {"enum": ["draft", "verified", "frozen", "deprecated"]},
    "version": {"type": "string"}
  }
}
