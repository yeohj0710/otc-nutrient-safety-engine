          "human_action_required": true,
          "status": "not_started"
        },
        {
          "id": "P3-T2",
          "title": "Complete title/abstract screening",
          "depends_on": [
            "P3-T1"
          ],
          "artifacts": [
            "research_v2/screening/title_abstract.csv"
          ],
          "acceptance_criteria": [
            "All records adjudicated; AI made no final exclusions"
          ],
          "human_action_required": true,
          "status": "not_started"
        },
        {
          "id": "P3-T3",
          "title": "Retrieve and assess full texts",
          "depends_on": [
            "P3-T2"
          ],
          "artifacts": [
            "research_v2/full_text/retrieval_log.csv",
            "research_v2/screening/full_text.csv"
          ],
          "acceptance_criteria": [
            "Every report has decision or documented retrieval attempts"
          ],
          "human_action_required": true,
          "status": "not_started"
        },
        {
          "id": "P3-T4",
          "title": "Generate validated PRISMA counts",
          "depends_on": [
            "P3-T3"
          ],
          "artifacts": [
            "research_v2/screening/prisma_counts.json",
            "research_v2/screening/prisma_flow.svg"
          ],
          "acceptance_criteria": [
            "Arithmetic checks pass; studies and reports distinguished"
          ],
          "human_action_required": false,
          "status": "not_started"
        }
      ]
