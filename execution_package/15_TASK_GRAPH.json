          "acceptance_criteria": [
            "Model versions, prompt hashes and parameters recorded"
          ],
          "human_action_required": false,
          "status": "not_started"
        },
        {
          "id": "P5-T2",
          "title": "Evaluate screening on held-out set",
          "depends_on": [
            "P5-T1",
            "P3-T2"
          ],
          "artifacts": [
            "research_v2/ai_eval/screening_predictions.csv",
            "research_v2/ai_eval/screening_metrics.json"
