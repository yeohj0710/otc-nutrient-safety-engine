        {
          "id": "P6-T2",
          "title": "Select focused node by prespecified rule",
          "depends_on": [
            "P6-T1"
          ],
          "artifacts": [
            "research_v2/synthesis/focused_node_decision.json"
          ],
          "acceptance_criteria": [
            "All candidate nodes scored before selection"
