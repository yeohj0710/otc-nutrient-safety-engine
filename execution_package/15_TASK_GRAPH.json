      "tasks": [
        {
          "id": "P5-T1",
          "title": "Freeze models and prompts",
          "depends_on": [
            "P3-T1"
          ],
          "artifacts": [
            "research_v2/ai_eval/run_manifest.json",
            "research_v2/ai_eval/prompts/"
