    {
      "phase": "P4",
      "name": "Extraction and evidence appraisal",
      "tasks": [
        {
          "id": "P4-T1",
          "title": "Pilot and complete verified extraction",
          "depends_on": [
            "P3-T3"
          ],
          "artifacts": [
            "research_v2/extraction/extraction.csv",
            "research_v2/extraction/source_quotes.csv"
          ],
          "acceptance_criteria": [
            "All included studies have verified values, units and locators"
          ],
          "human_action_required": true,
          "status": "not_started"
        },
        {
          "id": "P4-T2",
          "title": "Assess risk of bias",
          "depends_on": [
            "P4-T1"
          ],
          "artifacts": [
            "research_v2/risk_of_bias/assessments.csv"
          ],
          "acceptance_criteria": [
            "Design-appropriate tools; disagreements adjudicated"
          ],
          "human_action_required": true,
          "status": "not_started"
        },
        {
          "id": "P4-T3",
          "title": "Grade certainty by outcome",
          "depends_on": [
            "P4-T2"
          ],
          "artifacts": [
            "research_v2/synthesis/grade.csv"
          ],
          "acceptance_criteria": [
            "All critical outcomes have domain rationale"
          ],
          "human_action_required": true,
          "status": "not_started"
        }
      ]
