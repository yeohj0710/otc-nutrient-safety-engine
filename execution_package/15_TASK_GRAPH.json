          "acceptance_criteria": [
            "Seed set retrieved; platform translations checked"
          ],
          "human_action_required": true,
          "status": "awaiting_peer_review"
        },
        {
          "id": "P2-T2",
          "title": "Run full searches and preserve raw exports",
          "depends_on": [
            "P2-T1"
          ],
          "artifacts": [
            "research_v2/search/search_run_log.csv",
            "research_v2/search/raw/"
          ],
          "acceptance_criteria": [
            "No top-N truncation; hit/export/import reconciled"
          ],
          "human_action_required": false,
          "status": "blocked_by_P2_T1"
        },
        {
          "id": "P2-T3",
          "title": "Deduplicate and build study families",
          "depends_on": [
            "P2-T2"
          ],
          "artifacts": [
            "research_v2/search/normalized/records.parquet",
            "research_v2/search/dedup_log.csv"
          ],
          "acceptance_criteria": [
            "Duplicate audit sample reviewed; study families linked"
          ],
          "human_action_required": false,
          "status": "not_started"
        }
      ]
    },
