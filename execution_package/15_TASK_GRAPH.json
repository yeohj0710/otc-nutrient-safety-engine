      "tasks": [
        {
          "id": "P0-T1",
          "title": "Inspect git remote, project identity, deployment and student markers",
          "depends_on": [],
          "artifacts": [
            "research_v2/audit/repo_identity.json"
          ],
          "acceptance_criteria": [
            "All identity fields match Kwon and Yeo package markers are isolated from active research"
          ],
          "human_action_required": false,
          "status": "completed"
        },
        {
          "id": "P0-T2",
          "title": "Inventory and quarantine legacy assets",
          "depends_on": [
            "P0-T1"
          ],
          "artifacts": [
            "research_v2/audit/legacy_inventory.csv",
            "research_v2/legacy_untrusted/README.md"
          ],
          "acceptance_criteria": [
            "No legacy metric is imported into v2 without provenance"
          ],
          "human_action_required": false,
          "status": "completed"
        },
        {
          "id": "P0-T3",
          "title": "Implement Gate 0 automated identity test",
          "depends_on": [
            "P0-T1"
          ],
          "artifacts": [
            "execution_package/scripts/check_project_identity.py"
          ],
          "acceptance_criteria": [
            "Test fails on Yeo markers in Kwon active release data"
          ],
          "human_action_required": false,
          "status": "completed"
        }
      ]
    },
    {
      "phase": "P1",
      "name": "Protocol and registration",
      "tasks": [
        {
          "id": "P1-T1",
          "title": "Finalize protocol and clinical nodes",
          "depends_on": [
            "P0-T2"
          ],
          "artifacts": [
            "research_v2/protocol/protocol.md",
            "research_v2/protocol/eligibility.json"
          ],
          "acceptance_criteria": [
            "Five nodes and outcomes fixed; amendments process present"
          ],
          "human_action_required": true,
          "status": "awaiting_human_approval"
        },
        {
          "id": "P1-T2",
          "title": "Freeze protocol hash and register",
          "depends_on": [
            "P1-T1"
          ],
          "artifacts": [
            "research_v2/protocol/protocol.sha256",
            "research_v2/protocol/registration.json"
          ],
          "acceptance_criteria": [
            "Timestamp, commit and public/private registration location recorded"
          ],
          "human_action_required": true,
          "status": "blocked_by_P1_T1"
        }
      ]
    },
    {
      "phase": "P2",
      "name": "Search",
      "tasks": [
        {
          "id": "P2-T1",
          "title": "Develop and peer-review database search strategies",
          "depends_on": [
            "P1-T1"
          ],
          "artifacts": [
            "research_v2/search/search_strategies.csv",
            "research_v2/search/peer_review.csv"
