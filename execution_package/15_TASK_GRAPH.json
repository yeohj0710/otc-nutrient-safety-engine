          "title": "Create calibration and gold-standard screening sets",
          "depends_on": [
            "P2-T3"
          ],
          "artifacts": [
            "research_v2/ai_eval/screening_gold.csv",
            "research_v2/screening/calibration.csv"
          ],
          "acceptance_criteria": [
            "At least 300 gold items and 60 positives; group split"
